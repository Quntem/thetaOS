KEYSTONE_API_URL=https://keystoneapi.qplus.cloud
GRID_AGENT_BINARY_PATH=/usr/libexec/grid-client/grid-agent
KEYSTONEDIR_SERVICE_BINARY_PATH=/usr/libexec/grid-client/keystonedir-service
KEYSTONEDIR_ENROLL_BINARY_PATH=/usr/libexec/grid-client/keystonedir-enroll-util
KEYSTONEDIR_REFRESH_BINARY_PATH=/usr/libexec/grid-client/keystonedir-refresh-util
GRID_CLIENT_TLS_REJECT_UNAUTHORIZED=0
GRID_CLIENT_SERVICE_PORT=7000
KEYSTONEDIR_DEVICE_CONFIG_PATH=/etc/keystonedir/device.json
KEYSTONEDIR_USER_CONFIG_PATH=/etc/keystonedir/user.json
GRID_MANIFEST_PATH=/etc/grid/manifest.json
